---
interface Props {
  theme?: 'dark' | 'light';
  title?: string;
}
const { theme = 'dark', title = "Quincy So" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme={theme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Host+Grotesk:wght@700&display=swap" rel="stylesheet" />
  {theme === 'light' && (
    <>
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
    </>
  )}
  <style is:global>
    :root[data-theme="dark"] {
      --bg: #0e0e0e;
      --fg: #f0f0f0;
      --accent: #c8f540;
      --muted: #888;
      --border: #222;
      --card-bg: #1a1a1a;
      --font-display: 'Plus Jakarta Sans', sans-serif;
      --font-body: 'Host Grotesk', sans-serif;
      --max-w: 720px;
    }

    :root[data-theme="light"] {
      --bg: #faf9f6;
      --fg: #1a1a1a;
      --muted: #666;
      --border: #e0ddd6;
      --accent: #1a1a1a;
      --card-bg: #f2f0eb;
      --font-display: 'Plus Jakarta Sans', sans-serif;
      --font-body: 'Lora', serif;
      --max-w: 720px;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg);
      color: var(--fg);
      font-family: var(--font-body);
      font-size: 1.05rem;
      line-height: 1.8;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* NAV */
    nav {
      display: flex;
      gap: 2rem;
      padding: 1.1rem 2rem;
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
    }

    nav a {
      color: var(--muted);
      text-decoration: none;
      font-family: var(--font-display);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    nav a:hover { color: var(--fg); }

    /* MAIN */
    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: 4rem 2rem;
      max-width: 640px;
      width: 100%;
    }

    /* Dark theme (main style): container centered, text left-aligned */
    :root[data-theme="dark"] main {
      justify-content: center;
      margin: 0 auto; /* centered container */
      text-align: left; /* left-aligned text */
    }

    /* Light theme (editorial style): article wrapper centered */
    :root[data-theme="light"] main {
      justify-content: flex-start;
      align-items: stretch;
      max-width: var(--max-w);
      margin: 0 auto; /* centered container */
    }

    :root[data-theme="light"] main > article {
      max-width: var(--max-w);
      margin: 0 auto;
      width: 100%;
    }

    /* Dark theme home page styles */
    :root[data-theme="dark"] main h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 8vw, 5rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    :root[data-theme="dark"] main h1 span {
      color: var(--accent);
    }

    :root[data-theme="dark"] main .tagline {
      font-size: 0.9rem;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 2.5rem;
    }

    :root[data-theme="dark"] main .contact {
      font-size: 0.85rem;
      color: var(--muted);
    }

    :root[data-theme="dark"] main .contact a {
      color: var(--fg);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    :root[data-theme="dark"] main .contact a:hover {
      color: var(--accent);
    }

    /* Light theme legal page styles */
    :root[data-theme="light"] main .article-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
      border-bottom: 2px solid var(--fg);
    }

    :root[data-theme="light"] main .article-header h1 {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 0.75rem;
    }

    :root[data-theme="light"] main .article-header .subtitle {
      font-family: var(--font-display);
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--muted);
      margin-bottom: 1rem;
    }

    :root[data-theme="light"] main .article-header .byline {
      font-size: 0.85rem;
      color: var(--muted);
      font-style: italic;
    }

    :root[data-theme="light"] main p { margin-bottom: 1.2rem; }

    :root[data-theme="light"] main a { color: var(--fg); }
    :root[data-theme="light"] main a:hover { opacity: 0.6; }

    :root[data-theme="light"] main h2 {
      font-family: var(--font-display);
      font-size: 1.55rem;
      font-weight: 800;
      margin: 2.5rem 0 0.75rem;
      line-height: 1.2;
    }

    :root[data-theme="light"] main h3 {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 700;
      margin: 2rem 0 0.5rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    :root[data-theme="light"] main ul,
    :root[data-theme="light"] main ol {
      padding-left: 1.4rem;
      margin-bottom: 1.2rem;
    }

    :root[data-theme="light"] main li {
      margin-bottom: 0.35rem;
    }

    :root[data-theme="light"] main .notice {
      background: var(--card-bg);
      border: 1px solid var(--border);
      padding: 1rem 1.25rem;
      font-size: 0.9rem;
      margin: 1.5rem 0;
      font-style: italic;
      color: var(--muted);
    }

    :root[data-theme="light"] main blockquote {
      border-left: 3px solid var(--border);
      padding-left: 1rem;
      margin: 1.5rem 0;
      font-style: italic;
      color: var(--muted);
    }

    :root[data-theme="light"] main hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2.5rem 0;
    }

    /* Blog prose styles (dark theme) */
    :root[data-theme="dark"] main .prose {
      line-height: 1.6;
      font-weight: 400;
    }
    :root[data-theme="dark"] main .prose h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }
    :root[data-theme="dark"] main .prose h2 {
      font-size: 1.8rem;
      margin-top: 2rem;
      margin-bottom: 1rem;
    }
    :root[data-theme="dark"] main .prose h3 {
      font-size: 1.4rem;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }
    :root[data-theme="dark"] main .prose p {
      margin-bottom: 1rem;
    }
    :root[data-theme="dark"] main .prose a {
      color: var(--accent);
      text-decoration: none;
    }
    :root[data-theme="dark"] main .prose a:hover {
      text-decoration: underline;
    }
    :root[data-theme="dark"] main .prose img {
      max-width: 100%;
      height: auto;
      border-radius: 4px;
      margin: 1rem 0;
    }
    :root[data-theme="dark"] main .prose ul, .prose ol {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
    }

    /* FOOTER */
    footer {
      text-align: center;
      padding: 2rem;
      font-size: 0.8rem;
      color: var(--muted);
      border-top: 1px solid var(--border);
      font-family: var(--font-display);
      margin-top: auto;
    }

    :root[data-theme="dark"] footer {
      padding: 1rem 2rem;
      font-size: 0.75rem;
      color: #444;
      border-top: 1px solid #1a1a1a;
    }

    footer a {
      color: var(--muted);
    }

    footer a:hover {
      color: var(--fg);
    }
  </style>
</head>
<body>

  <nav>
    <a href="/">Home</a>
    <a href="/blog">Blog</a>
    <a href="http://status.soquincy.qzz.io" target="_blank" rel="noopener">Projects Status</a>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    Quincy So &nbsp;·&nbsp; Observe. Reflect. Create. &nbsp;·&nbsp; <a href="mailto:hello@soquincy.qzz.io">hello@soquincy.qzz.io</a>
  </footer>

</body>
</html>
