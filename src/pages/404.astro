---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <main style="min-height: 60vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 2rem;">
    <h1 style="font-size: clamp(3rem, 10vw, 6rem); font-weight: 800; margin-bottom: 1rem;">404</h1>
    <p style="font-size: 1.25rem; color: var(--muted); margin-bottom: 2rem;">Page Not Found</p>
    <p style="color: var(--muted);">The requested page could not be found.</p>
    <a href="/" style="display: inline-block; margin-top: 2rem; color: var(--accent); text-decoration: underline; text-underline-offset: 3px;">← Back to Home</a>
  </main>
</BaseLayout>

<style>
  :root {
    --bg: #0e0e0e;
    --fg: #f0f0f0;
    --accent: #c8f540;
    --muted: #888;
  }
</style>