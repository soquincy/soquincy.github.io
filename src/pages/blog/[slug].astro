---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout theme="light" showThemeToggle={true} title={post.data.title}>
  <article>
    {post.data.heroImage && <img class="article-img" src={post.data.heroImage} alt={post.data.title} />}
    <header class="article-header">
      <h1>{post.data.title}</h1>
      {post.data.description && <p class="subtitle">{post.data.description}</p>}
      <p class="byline">{post.data.pubDate.toISOString().split('T')[0]}</p>
    </header>
    <Content />
  </article>
</BaseLayout>
